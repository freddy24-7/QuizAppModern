# Spring profile — use "prod" on Railway
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL (provided automatically by Railway Postgres plugin)
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Frontend origin (used for CORS and WebSocket allowed origins)
APP_FRONTEND_URL=https://your-frontend.vercel.app

# Server port (Railway sets this automatically)
PORT=8080
